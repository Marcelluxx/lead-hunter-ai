# Google Maps Places API Key (Requires Places API V1 enabled)
GOOGLE_API_KEY=your_google_api_key_here

# OpenRouter API Key for AI Auditing
OPENROUTER_API_KEY=your_openrouter_api_key_here

# AI Model for Auditing (e.g., meta-llama/llama-3.1-8b-instruct or similar)
LLM_MODEL=meta-llama/llama-3.1-8b-instruct
